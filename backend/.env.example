# 服务配置
APP_NAME=AI Voice Draw
DEBUG=true
HOST=0.0.0.0
PORT=8000

# CORS（前端开发地址）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 语音识别：本地 Whisper 免费（推荐）
SPEECH_PROVIDER=local
WHISPER_LOCAL_MODEL=base

# Hugging Face 国内镜像（下载 Whisper 模型）
HUGGINGFACE_ENDPOINT=https://hf-mirror.com
HUGGINGFACE_HUB_DISABLE_SSL=true
# WHISPER_LOCAL_MODEL_PATH=D:/models/faster-whisper-base

# 可选：OpenAI Whisper API（需 Key）
# SPEECH_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key-here
# 推荐：Stable Horde 免费服务（无需 API Key）
IMAGE_PROVIDER=stablehorde

# auto=有 OpenAI Key 用 DALL·E，否则 Stable Horde
# IMAGE_PROVIDER=auto
# IMAGE_PROVIDER=openai
# IMAGE_PROVIDER=pollinations

# OpenAI DALL·E（步骤 3，需 Key）
# OPENAI_API_KEY=sk-your-key-here
# IMAGE_API_KEY=
# IMAGE_MODEL=dall-e-3
# IMAGE_QUALITY=standard

# Stable Horde（步骤 4 修复，推荐免费方案）
# STABLE_HORDE_API_KEY=0000000000
# STABLE_HORDE_MAX_WAIT_SECONDS=180
# STABLE_HORDE_STEPS=20
# STABLE_HORDE_MODELS=

# Pollinations（已收费 402，不推荐）
# POLLINATIONS_BASE_URL=https://image.pollinations.ai
# POLLINATIONS_MODEL=flux

# 生成历史（默认开启，保存在 backend/data/history/）
HISTORY_ENABLED=true
HISTORY_MAX_ITEMS=100
